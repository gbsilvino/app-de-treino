{
  "name": "gspro",
  "version": "1.0.0",
  "description": "App de Treinamento",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "dist": "electron-builder --win nsis",
    "shortcut": "node create-shortcut.js"
  },
  "author": "Seu Nome",
  "license": "MIT",
  "build": {
    "appId": "com.gspro.app",
    "productName": "GSPro Treinos",
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0"
  }
}
